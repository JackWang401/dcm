KONSERVIERUNG_FORMAT 2.0

FESTWERT IDLE_SPEED_LIMIT
  LANGNAME "Idle speed limit"
  EINHEIT_W "rpm"
  WERT 750
END

FESTWERTEBLOCK INJECTION_OFFSET_VECTOR
  LANGNAME "Cylinder offset vector"
  WERT 0.10 0.15 0.17 0.14
END

KENNLINIE TORQUE_REQUEST_CURVE
  LANGNAME "Torque request over pedal"
  ST/X 0 25 50 75 100
  WERT 0 65 130 205 280
END

KENNFELD BOOST_TARGET_MAP
  LANGNAME "Boost target map"
  ST/X 1000 2000 3000 4000
  ST/Y 10 30 60
  WERT 1050 1120 1180 1250
  WERT 1100 1180 1250 1330
  WERT 1140 1230 1310 1400
END
